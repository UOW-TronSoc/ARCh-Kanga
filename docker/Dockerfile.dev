FROM ros:humble-ros-base-jammy

# Initial Kanga ROS 2 development/build image.
# Docker handles the ROS 2 software/build environment only.
# The host is responsible for hardware and OS-level setup (drivers, CAN interfaces, etc.).

ENV ROS_DISTRO=humble
ENV WORKSPACE=/workspace
ENV DEBIAN_FRONTEND=noninteractive
SHELL ["/bin/bash", "-c"]

ARG USER_NAME=kanga
ARG USER_UID=1000
ARG USER_GID=1000

COPY docker/apt-packages.txt /tmp/apt-packages.txt

RUN apt-get update \
    && xargs -r apt-get install -y --no-install-recommends < /tmp/apt-packages.txt \
    && rm -f /tmp/apt-packages.txt \
    && rm -rf /var/lib/apt/lists/*

# Match the development user to the host so bind-mounted build files are not
# owned by root. sudo is retained for rosdep to install declared dependencies.
RUN groupadd --gid "${USER_GID}" "${USER_NAME}" \
    && useradd --uid "${USER_UID}" --gid "${USER_GID}" --create-home \
        --shell /bin/bash "${USER_NAME}" \
    && echo "${USER_NAME} ALL=(root) NOPASSWD:ALL" \
        > "/etc/sudoers.d/${USER_NAME}" \
    && chmod 0440 "/etc/sudoers.d/${USER_NAME}" \
    && (rosdep init 2>/dev/null || true)

ENV HOME=/home/${USER_NAME}
USER ${USER_NAME}

RUN rosdep update \
    && echo "source /opt/ros/${ROS_DISTRO}/setup.bash" >> "${HOME}/.bashrc" \
    && echo "if [ -f ${WORKSPACE}/install/setup.bash ]; then source ${WORKSPACE}/install/setup.bash; fi" >> "${HOME}/.bashrc"

WORKDIR /workspace

CMD ["bash"]
